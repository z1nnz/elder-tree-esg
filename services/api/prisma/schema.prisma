generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PARTICIPANT
  FAMILY
  REVIEWER
  ORG_ADMIN
  PLATFORM_ADMIN
}

enum VerificationMode {
  PHOTO_AI
  SELF_CHECK
  TIMER
  STEP_COUNT
  LOCATION_CHECK_IN
  DEVICE_CONFIRM
}

enum AssignmentStatus {
  AVAILABLE
  IN_PROGRESS
  VERIFYING
  COMPLETED
  REJECTED
}

enum VerificationDecision {
  PASS
  REVIEW
  FAIL
}

enum EvidenceStatus {
  PENDING_UPLOAD
  PROCESSING
  AWAITING_REVIEW
  RESOLVED
  ERROR
}

enum QuestTriggerType {
  DISTANCE
  GEOFENCE
}

enum ExplorationRouteStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ExplorationSessionStatus {
  ACTIVE
  ENDED
  EXPIRED
}

enum RadarMissionPublicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CompanionPromptSource {
  RADAR_MISSION
}

enum TreeStage {
  SEED
  SPROUT
  SEEDLING
  YOUNG_TREE
  MATURE
}

enum ImpactBatchStatus {
  DRAFT
  SIMULATED
  PUBLISHED
  ARCHIVED
}

model User {
  id                String            @id @default(uuid())
  firebaseUid       String            @unique
  displayName       String
  role              UserRole
  activeHouseholdId String?
  activeHousehold   Household?        @relation("ActiveHousehold", fields: [activeHouseholdId], references: [id], onDelete: SetNull)
  householdLinks    HouseholdMember[]
  assignments       TaskAssignment[]
  messages          FamilyMessage[]
  createdInvites    HouseholdInvite[] @relation("InviteCreator")
  usedInvites       HouseholdInvite[] @relation("InviteUser")
  reviews            VerificationRun[] @relation("VerificationReviewer")
  explorationProgress ExplorationProgress[]
  explorationSessions ExplorationSession[]
  explorationAwards   ExplorationRouteAward[]
  locationReceipts    LocationEventReceipt[]
  questUnlocks        QuestUnlock[]
  radarMissionProgress RadarMissionProgress[]
  companionPrompts CompanionPrompt[]
  lineBindings       LineBinding[]
  lineBindingCodes   LineBindingCode[]
  auditLogs         AuditLog[]        @relation("AuditActor")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Household {
  id          String            @id @default(uuid())
  name        String
  activeUsers User[]            @relation("ActiveHousehold")
  members     HouseholdMember[]
  assignments TaskAssignment[]
  devices     Device[]
  trees       Tree[]
  messages    FamilyMessage[]
  invites     HouseholdInvite[]
  explorationProgress ExplorationProgress[]
  explorationSessions ExplorationSession[]
  explorationAwards ExplorationRouteAward[]
  locationReceipts LocationEventReceipt[]
  questUnlocks QuestUnlock[]
  radarMissionProgress RadarMissionProgress[]
  companionPrompts CompanionPrompt[]
  lineBindings LineBinding[]
  lineBindingCodes LineBindingCode[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model HouseholdMember {
  householdId String
  userId      String
  relationship String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([householdId, userId])
}

model Device {
  id              String      @id @default(uuid())
  thingName       String      @unique
  serialNumber    String      @unique
  claimCodeHash   String
  householdId     String?
  firmwareVersion String
  lastSeenAt      DateTime?
  desiredState    Json?
  reportedState   Json?
  household       Household?  @relation(fields: [householdId], references: [id])
  events          DeviceEvent[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model DeviceEvent {
  id         String   @id @default(uuid())
  deviceId   String
  eventKey   String   @unique
  eventType  String
  payload    Json
  occurredAt DateTime
  device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Task {
  id               String             @id @default(uuid())
  title            String
  description      String
  verificationMode VerificationMode
  verificationRule Json
  growthPoints     Int
  assignments      TaskAssignment[]
  mapQuest         MapQuest?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model MapQuest {
  id                   String           @id @default(uuid())
  taskId               String           @unique
  routeId              String
  sequence             Int
  locationName         String
  category             String
  safetyNote           String?
  accessibilityTags    String[]         @default([])
  sourceUrl            String?
  triggerType          QuestTriggerType
  latitude             Float?
  longitude            Float?
  radiusMeters         Int?
  unlockDistanceMeters Int?
  active               Boolean          @default(true)
  task                 Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  route                ExplorationRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  unlocks              QuestUnlock[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@unique([routeId, sequence])
  @@index([routeId, active])
}

model ExplorationRoute {
  id            String                 @id @default(uuid())
  slug          String                 @unique
  name          String
  description   String
  badgeName     String
  badgeAssetKey String
  version       Int                    @default(1)
  status        ExplorationRouteStatus @default(DRAFT)
  publishedAt   DateTime?
  archivedAt    DateTime?
  quests        MapQuest[]
  sessions      ExplorationSession[]
  awards        ExplorationRouteAward[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model ExplorationSession {
  id             String                   @id @default(uuid())
  routeId        String
  userId         String
  householdId    String
  status         ExplorationSessionStatus @default(ACTIVE)
  distanceMeters Int                      @default(0)
  lastLatitude   Float?
  lastLongitude  Float?
  lastAccuracy   Float?
  lastEventAt    DateTime?
  startedAt      DateTime                 @default(now())
  endedAt        DateTime?
  route          ExplorationRoute         @relation(fields: [routeId], references: [id], onDelete: Cascade)
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  household      Household                @relation(fields: [householdId], references: [id], onDelete: Cascade)
  receipts       LocationEventReceipt[]

  @@index([userId, householdId, status])
  @@index([routeId, status])
}

model ExplorationRouteAward {
  id          String           @id @default(uuid())
  routeId     String
  userId      String
  householdId String
  route       ExplorationRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  awardedAt   DateTime         @default(now())

  @@unique([routeId, userId, householdId])
  @@index([userId, householdId])
}

model ExplorationProgress {
  id                  String    @id @default(uuid())
  userId              String
  householdId         String
  totalDistanceMeters Int       @default(0)
  lastEventAt         DateTime?
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household           Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([userId, householdId])
}

model LocationEventReceipt {
  id             String    @id @default(uuid())
  eventKey       String    @unique
  sessionId      String?
  userId         String
  householdId    String
  coarseCell     String
  distanceMeters Int
  occurredAt     DateTime
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household      Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  session        ExplorationSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())

  @@index([sessionId, occurredAt])
}

model QuestUnlock {
  id          String    @id @default(uuid())
  questId     String
  userId      String
  householdId String
  quest       MapQuest  @relation(fields: [questId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  unlockedAt  DateTime  @default(now())

  @@unique([questId, userId, householdId])
}

model RadarMission {
  id               String                        @id @default(uuid())
  title            String
  description      String
  category         String
  tag              String
  latitude         Float
  longitude        Float
  radiusMeters     Int
  startsAt         DateTime
  endsAt           DateTime
  verificationMode VerificationMode
  minimumSeconds   Int?
  growthPoints     Int
  badgeName        String?
  companionElderMessageTemplate String?
  companionReplyTemplate String?
  companionVolunteerNoteTemplate String?
  companionShareSummaryTemplate String?
  status           RadarMissionPublicationStatus @default(DRAFT)
  publishedAt      DateTime?
  archivedAt       DateTime?
  progress         RadarMissionProgress[]
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt

  @@index([status, startsAt, endsAt])
  @@index([latitude, longitude])
}

model RadarMissionProgress {
  id          String       @id @default(uuid())
  missionId   String
  userId      String
  householdId String
  unlockedAt  DateTime    @default(now())
  completedAt DateTime?
  lastEventKey String?
  mission     RadarMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  companionPrompt CompanionPrompt?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([missionId, userId, householdId])
  @@index([userId, householdId, completedAt])
}

model CompanionPrompt {
  id                     String                @id @default(uuid())
  sourceType             CompanionPromptSource @default(RADAR_MISSION)
  radarMissionProgressId String                @unique
  userId                 String
  householdId            String
  sourceTitle            String
  category               String
  tag                    String
  growthPoints           Int
  elderMessage           String
  companionReply         String
  volunteerNote          String
  shareSummary           String
  radarMissionProgress   RadarMissionProgress  @relation(fields: [radarMissionProgressId], references: [id], onDelete: Cascade)
  user                   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  household              Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt              DateTime              @default(now())

  @@index([userId, householdId, createdAt])
  @@index([householdId, createdAt])
}

model TaskAssignment {
  id          String           @id @default(uuid())
  taskId      String
  userId      String
  householdId String
  status      AssignmentStatus @default(AVAILABLE)
  startedAt   DateTime?
  dueAt       DateTime?
  completedAt DateTime?
  task        Task             @relation(fields: [taskId], references: [id])
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  evidence    Evidence[]
  photoVerificationAttempts PhotoVerificationAttempt[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([taskId, userId, householdId])
}

model PhotoVerificationAttempt {
  id             String               @id @default(uuid())
  assignmentId   String
  idempotencyKey String
  decision       VerificationDecision
  labels         Json
  matchedLabels  String[]             @default([])
  confidence     Float
  reasonCodes    String[]             @default([])
  model          String
  ruleVersion    String
  assignment     TaskAssignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now())

  @@unique([assignmentId, idempotencyKey])
  @@index([assignmentId, createdAt])
}

model HouseholdInvite {
  id          String     @id @default(uuid())
  householdId String
  createdById String
  codeHash    String     @unique
  expiresAt   DateTime
  usedAt      DateTime?
  usedById    String?
  household   Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy   User       @relation("InviteCreator", fields: [createdById], references: [id], onDelete: Cascade)
  usedBy      User?      @relation("InviteUser", fields: [usedById], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
}

model Evidence {
  id           String            @id @default(uuid())
  assignmentId String
  storagePath  String
  contentType  String
  status       EvidenceStatus    @default(PENDING_UPLOAD)
  errorCode    String?
  sha256       String?
  uploadedAt   DateTime?
  assignment   TaskAssignment    @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  verification VerificationRun?
  createdAt    DateTime          @default(now())
}

model VerificationRun {
  id             String               @id @default(uuid())
  evidenceId     String               @unique
  decision       VerificationDecision
  confidence     Float
  labels         String[]
  reasonCodes    String[]
  explanation    String
  model          String
  ruleVersion    String
  reviewedById   String?
  reviewedAt     DateTime?
  evidence       Evidence             @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  reviewedBy     User?                @relation("VerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model Tree {
  id           String      @id @default(uuid())
  householdId  String
  name         String
  stage        TreeStage   @default(SEED)
  growthPoints Int         @default(0)
  household    Household   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ledger       GrowthEntry[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model GrowthEntry {
  id             String   @id @default(uuid())
  treeId         String
  idempotencyKey String   @unique
  points         Int
  reason         String
  sourceId       String?
  tree           Tree     @relation(fields: [treeId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
}

model FamilyMessage {
  id                  String    @id @default(uuid())
  householdId         String
  authorId            String
  body                String
  deliveredToDeviceAt DateTime?
  household           Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  author              User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt           DateTime  @default(now())
}

model LineBinding {
  id          String    @id @default(uuid())
  userId      String
  householdId String
  lineUserId  String
  status      String    @default("ACTIVE")
  revokedAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  notifications LineNotificationLog[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([lineUserId, householdId])
  @@index([userId, householdId, status])
}

model LineBindingCode {
  id          String    @id @default(uuid())
  codeHash    String    @unique
  userId      String
  householdId String
  expiresAt   DateTime
  usedAt      DateTime?
  lineUserId  String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([userId, householdId, expiresAt])
}

model LineNotificationLog {
  id            String       @id @default(uuid())
  lineBindingId String?
  target        String
  type          String
  status        String
  error         String?
  lineBinding   LineBinding? @relation(fields: [lineBindingId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())

  @@index([lineBindingId, createdAt])
  @@index([type, status, createdAt])
}

model Organization {
  id          String          @id @default(uuid())
  name        String
  memberships OrganizationMember[]
  campaigns   Campaign[]
  batches     ImpactBatch[]
  createdAt   DateTime        @default(now())
}

model OrganizationMember {
  organizationId String
  userId         String
  role           UserRole
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([organizationId, userId])
}

model Campaign {
  id             String       @id @default(uuid())
  organizationId String
  title          String
  startsAt       DateTime
  endsAt         DateTime
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
}

model ImpactPoolEntry {
  id             String   @id @default(uuid())
  idempotencyKey String   @unique
  points         Int
  sourceType     String
  sourceId       String
  allocatedAt    DateTime?
  createdAt      DateTime @default(now())
}

model ImpactBatch {
  id               String            @id @default(uuid())
  organizationId   String?
  title            String
  status           ImpactBatchStatus @default(DRAFT)
  simulated        Boolean           @default(true)
  allocatedPoints  Int
  equivalentTrees  Float
  evidenceMetadata Json?
  publishedAt      DateTime?
  organization     Organization?     @relation(fields: [organizationId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  createdAt  DateTime @default(now())
}
